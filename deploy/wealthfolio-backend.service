[Unit]
Description=Wealthfolio Backend (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/home/deploy/wealthfolio/backend
ExecStart=/home/deploy/wealthfolio/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

# Logging
StandardOutput=append:/home/deploy/wealthfolio/backend/server.log
StandardError=append:/home/deploy/wealthfolio/backend/server.log

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/deploy/wealthfolio/backend

[Install]
WantedBy=multi-user.target
